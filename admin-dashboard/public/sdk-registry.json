{
  "sdks": [
    {
      "id": "typescript",
      "name": "TypeScript SDK",
      "language": "TypeScript",
      "description": "The official Fluid client for TypeScript and JavaScript. Works in Node.js, browsers, and edge runtimes.",
      "installCommand": "npm install fluid-client",
      "registry": "npm",
      "packageName": "fluid-client",
      "docsUrl": "https://docs.fluid.dev/sdk/typescript",
      "typeDocUrl": "https://docs.fluid.dev/typedoc/typescript",
      "repoUrl": "https://github.com/Stellar-Fluid/fluid/tree/main/client",
      "latestVersion": "1.3.0",
      "versions": [
        {
          "version": "1.3.0",
          "date": "2026-03-01",
          "changes": [
            "Add `requestFeeBumpBatch` for submitting multiple XDRs in one call",
            "Expose `FluidClient.healthCheck()` to ping the server before submitting",
            "Reduce bundle size by 18% via tree-shaking improvements"
          ]
        },
        {
          "version": "1.2.1",
          "date": "2026-01-15",
          "changes": [
            "Fix retry logic not honouring the `maxRetries` option",
            "Correctly pass `networkPassphrase` to fee-bump envelope builder"
          ]
        },
        {
          "version": "1.2.0",
          "date": "2025-11-20",
          "changes": [
            "Add Soroban RPC support via `requestSorobanFeeBump`",
            "New `onRetry` callback for observing retry attempts",
            "Improve error messages with Horizon result codes"
          ]
        },
        {
          "version": "1.1.0",
          "date": "2025-09-08",
          "changes": [
            "Support configurable `timeout` per request",
            "Add `FluidError` typed exception with `statusCode` and `code` fields",
            "Publish ESM and CJS builds"
          ]
        }
      ]
    },
    {
      "id": "python",
      "name": "Python SDK",
      "language": "Python",
      "description": "Async-first Python client for the Fluid API. Built on httpx with full type annotations and Django/FastAPI middleware.",
      "installCommand": "pip install fluid-py",
      "registry": "pypi",
      "packageName": "fluid-py",
      "docsUrl": "https://docs.fluid.dev/sdk/python",
      "typeDocUrl": "https://docs.fluid.dev/typedoc/python",
      "repoUrl": "https://github.com/Stellar-Fluid/fluid-py",
      "latestVersion": "0.9.2",
      "versions": [
        {
          "version": "0.9.2",
          "date": "2026-02-18",
          "changes": [
            "Fix `FluidClient.close()` not awaiting underlying httpx session",
            "Add `py.typed` marker for PEP 561 compatibility"
          ]
        },
        {
          "version": "0.9.0",
          "date": "2026-01-05",
          "changes": [
            "Add async batch endpoint support",
            "Django middleware: auto-inject `request.fluid_client`",
            "FastAPI dependency helper `get_fluid_client()`"
          ]
        },
        {
          "version": "0.8.0",
          "date": "2025-10-12",
          "changes": [
            "Initial stable release",
            "Full async/await API with httpx backend",
            "Pydantic v2 response models"
          ]
        }
      ]
    },
    {
      "id": "go",
      "name": "Go SDK",
      "language": "Go",
      "description": "Idiomatic Go client for Fluid. Thread-safe, context-aware, and compatible with the official Stellar Go SDK.",
      "installCommand": "go get github.com/Stellar-Fluid/fluid-go",
      "registry": "pkg.go.dev",
      "packageName": "github.com/Stellar-Fluid/fluid-go",
      "docsUrl": "https://docs.fluid.dev/sdk/go",
      "typeDocUrl": "https://pkg.go.dev/github.com/Stellar-Fluid/fluid-go",
      "repoUrl": "https://github.com/Stellar-Fluid/fluid-go",
      "latestVersion": "v0.6.1",
      "versions": [
        {
          "version": "v0.6.1",
          "date": "2026-02-28",
          "changes": [
            "Fix context cancellation not propagating to HTTP round-tripper",
            "Add `WithTimeout` functional option"
          ]
        },
        {
          "version": "v0.6.0",
          "date": "2025-12-10",
          "changes": [
            "Add `Client.FeeBumpBatch()` for batch submissions",
            "Expose `HealthCheck()` method",
            "Improve error wrapping with `%w` for `errors.Is` compatibility"
          ]
        },
        {
          "version": "v0.5.0",
          "date": "2025-09-22",
          "changes": [
            "Initial public release",
            "Thread-safe client with `sync.Mutex` guard",
            "Full context.Context support on all methods"
          ]
        }
      ]
    },
    {
      "id": "react",
      "name": "React SDK",
      "language": "React",
      "description": "React hooks and context provider for Fluid. Includes `useFeeBump`, `useFluidClient`, and `useTransactionStatus` with built-in loading and error states.",
      "installCommand": "npm install fluid-react",
      "registry": "npm",
      "packageName": "fluid-react",
      "docsUrl": "https://docs.fluid.dev/sdk/react",
      "typeDocUrl": "https://docs.fluid.dev/typedoc/react",
      "repoUrl": "https://github.com/Stellar-Fluid/fluid-react",
      "latestVersion": "2.1.0",
      "versions": [
        {
          "version": "2.1.0",
          "date": "2026-03-10",
          "changes": [
            "React 19 support",
            "New `useTransactionStatus` hook for polling transaction state",
            "Add `FluidProvider` `onError` prop for global error handling"
          ]
        },
        {
          "version": "2.0.0",
          "date": "2026-01-20",
          "changes": [
            "Breaking: rename `useFluid` to `useFluidClient` for clarity",
            "Add `useFeeBumpBatch` hook",
            "Tree-shakeable named exports"
          ]
        },
        {
          "version": "1.0.0",
          "date": "2025-10-01",
          "changes": [
            "Initial stable release",
            "`FluidProvider`, `useFluidClient`, `useFeeBump` hooks",
            "Built-in suspense and error boundary support"
          ]
        }
      ]
    },
    {
      "id": "vue",
      "name": "Vue SDK",
      "language": "Vue",
      "description": "Vue 3 composables for Fluid. Drop-in `useFeeBump` and `useFluidClient` with Pinia store integration and automatic retry on network errors.",
      "installCommand": "npm install fluid-vue",
      "registry": "npm",
      "packageName": "fluid-vue",
      "docsUrl": "https://docs.fluid.dev/sdk/vue",
      "typeDocUrl": "https://docs.fluid.dev/typedoc/vue",
      "repoUrl": "https://github.com/Stellar-Fluid/fluid-vue",
      "latestVersion": "1.2.0",
      "versions": [
        {
          "version": "1.2.0",
          "date": "2026-02-05",
          "changes": [
            "Add Pinia plugin for automatic `fluidClient` store injection",
            "New `useTransactionStatus` composable",
            "Vue DevTools integration for inspecting fee-bump state"
          ]
        },
        {
          "version": "1.1.0",
          "date": "2025-11-15",
          "changes": [
            "Add `useFeeBumpBatch` composable",
            "Improve TypeScript generics on composable return types"
          ]
        },
        {
          "version": "1.0.0",
          "date": "2025-09-01",
          "changes": [
            "Initial release",
            "`useFluidClient` and `useFeeBump` composables",
            "Full Vue 3 Composition API support"
          ]
        }
      ]
    }
  ]
}
