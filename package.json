{
    "name":  "fluid",
    "version":  "1.22.0",
    "private":  true,
    "description":  "Fluid - Stellar fee sponsorship platform",
    "workspaces":  [
                       "client",
                       "client/examples/vue",
                       "server",
                       "admin-dashboard",
                       "fluid-server/wasm-demo"
                   ],
    "repository":  {
                       "type":  "git",
