// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SubscriptionTier {
  id           String   @id @default(uuid())
  name         String   @unique
  txLimit      Int
  rateLimit    Int
  priceMonthly Int
  tenants      Tenant[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Tenant {
  id                 String            @id @default(uuid())
  name               String
  subscriptionTierId String
  subscriptionTier   SubscriptionTier  @relation(fields: [subscriptionTierId], references: [id])
  dailyQuotaStroops  BigInt            @default(1000000) // 0.1 XLM default
  totalCredit        BigInt            @default(0) // Total purchased credit
  webhookUrl         String?
  webhookSecret      String?
  webhookEventTypes  String?
  apiKeys            ApiKey[]
  webhookDeliveries  WebhookDelivery[]
  quotaTopUps        QuotaTopUp[]
  payments           Payment[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([subscriptionTierId])
}

model ApiKey {
  id                String   @id @default(uuid())
  key               String   @unique
  prefix            String
  name              String   @default("Default API Key")
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  active            Boolean  @default(true)
  dailyQuotaStroops BigInt   @default(1000000) // 0.1 XLM default
  maxRequests       Int      @default(5)
  windowMs          Int      @default(60000)
  tier              String   @default("free") // free or pro
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model WebhookDelivery {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  url         String
  payload     String
  status      String   @default("pending") // pending, success, failed
  retryCount  Int      @default(0)
  lastError   String?
  nextAttempt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([tenantId])
}

model QuotaTopUp {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  stripeSessionId String   @unique
  amountCents     Int
  quotaStroops    BigInt
  status          String   @default("pending") // pending, fulfilled, failed
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
}

model Payment {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  stripeSessionId String   @unique
  stripePaymentId String?
  amountCents     Int
  creditStroops   BigInt
  status          String   @default("pending")
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
}

model SupportedAsset {
  id         String   @id @default(uuid())
  code       String
  issuer     String?
  minBalance String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([code, issuer])
}

model SponsoredTransaction {
  id         String   @id @default(uuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  feeStroops BigInt
  createdAt  DateTime @default(now())
}
model SignerSecret {
  id                String   @id @default(uuid())
  publicKey         String   @unique
  encryptedSecret   String
  initializationVec String
  authTag           String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model DeviceToken {
  id        String   @id @default(uuid())
  token     String   @unique
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([token])
}
